<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:gMKVToolNix.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="600"
        x:Class="gMKVToolNix.UI.Views.JobsWindow"
        x:DataType="vm:JobsWindowViewModel"
        Title="作业队列 · gMKVExtractGUI"
        Width="960" Height="620"
        MinWidth="720" MinHeight="440"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur,Mica,Blur,Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

  <Panel>
    <!-- 毛玻璃底层 -->
    <ExperimentalAcrylicBorder IsHitTestVisible="False">
      <ExperimentalAcrylicBorder.Material>
        <ExperimentalAcrylicMaterial
          BackgroundSource="Digger"
          TintColor="#DCD0F0"
          TintOpacity="0.55"
          MaterialOpacity="0.65" />
      </ExperimentalAcrylicBorder.Material>
    </ExperimentalAcrylicBorder>

    <Rectangle Fill="{StaticResource MacaronWindowBackground}" Opacity="0.35" IsHitTestVisible="False" />

    <!-- 主布局 -->
    <Grid Margin="20,16,20,16" RowDefinitions="Auto,Auto,*,Auto,Auto">

      <!-- ── 标题栏 ── -->
      <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,8,0,10">
        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2">
          <TextBlock Classes="h1" Text="作业队列" />
          <TextBlock Classes="subtitle" Text="批量提取任务管理" />
        </StackPanel>

        <!-- 工具栏按钮组 -->
        <WrapPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <Button Classes="macaron mint"
                  Content="▶ 开始全部"
                  Margin="0,0,6,0"
                  Command="{Binding RunAllCommand}"
                  IsEnabled="{Binding CanRunAll}"
                  ToolTip.Tip="执行所有等待中的任务" />
          <Button Classes="macaron lavender"
                  Content="⏸ 暂停"
                  Margin="0,0,6,0"
                  Command="{Binding PauseCommand}"
                  IsEnabled="{Binding CanPause}"
                  ToolTip.Tip="暂停执行（当前任务完成后生效）" />
          <Button Classes="macaron lemon"
                  Content="▶ 恢复"
                  Margin="0,0,6,0"
                  Command="{Binding ResumeCommand}"
                  IsEnabled="{Binding CanResume}"
                  ToolTip.Tip="继续执行队列" />
          <Button Classes="macaron"
                  Content="■ 中止全部"
                  Margin="0,0,6,0"
                  Command="{Binding AbortAllCommand}"
                  IsEnabled="{Binding CanAbort}"
                  ToolTip.Tip="立即中止所有任务" />
          <Button Classes="macaron sky"
                  Content="↺ 重试失败"
                  Margin="0,0,6,0"
                  Command="{Binding RetryFailedCommand}"
                  ToolTip.Tip="将所有失败任务重置为等待状态" />
          <Button Classes="macaron"
                  Content="移除选中"
                  Margin="0,0,6,0"
                  Command="{Binding RemoveSelectedCommand}"
                  ToolTip.Tip="移除选中的任务（运行中不可移除）" />
          <Button Classes="macaron"
                  Content="清空"
                  Command="{Binding ClearCommand}"
                  IsEnabled="{Binding !IsRunning}"
                  ToolTip.Tip="清空所有任务" />
        </WrapPanel>
      </Grid>

      <!-- ── 总进度条 ── -->
      <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,10">
        <TextBlock Grid.Column="0" VerticalAlignment="Center"
                   Classes="subtitle" Text="总进度" Margin="0,0,8,0" />
        <ProgressBar Grid.Column="1" Minimum="0" Maximum="100"
                     Value="{Binding OverallProgress}"
                     Height="12" CornerRadius="6"
                     Foreground="{StaticResource MacaronMintBrush}"
                     Background="#30000000" />
        <TextBlock Grid.Column="2" VerticalAlignment="Center"
                   Classes="subtitle" Margin="8,0,0,0"
                   Text="{Binding OverallProgress, StringFormat={}{0}%}" />
      </Grid>

      <!-- ── 任务 DataGrid ── -->
      <Border Grid.Row="2" Classes="glass" Padding="2">
        <Grid>
          <!-- 空状态提示 -->
          <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                      Spacing="8" IsVisible="{Binding IsEmpty}">
            <TextBlock FontSize="40" Text="📋" HorizontalAlignment="Center" />
            <TextBlock Classes="h2" HorizontalAlignment="Center" Text="队列空空如也" />
            <TextBlock Classes="subtitle" HorizontalAlignment="Center"
                       Text="在主窗口选好轨道后点「加入队列」即可" />
          </StackPanel>

          <!-- 任务列表 -->
          <DataGrid ItemsSource="{Binding Jobs}"
                    SelectedItem="{Binding SelectedJob}"
                    IsVisible="{Binding HasJobs}"
                    AutoGenerateColumns="False"
                    CanUserReorderColumns="False"
                    CanUserResizeColumns="True"
                    CanUserSortColumns="False"
                    GridLinesVisibility="Horizontal"
                    Background="Transparent"
                    BorderThickness="0"
                    RowBackground="Transparent"
                    HeadersVisibility="Column">

            <DataGrid.Columns>

              <!-- 状态标签 -->
              <DataGridTemplateColumn Header="状态" Width="78" IsReadOnly="True">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate x:DataType="vm:JobItem">
                    <Border Background="{Binding StatusColor}"
                            CornerRadius="6" Padding="6,2" Margin="4,2"
                            HorizontalAlignment="Center">
                      <TextBlock Text="{Binding StatusLabel}"
                                 FontSize="11" FontWeight="SemiBold"
                                 Foreground="{StaticResource MacaronTextBrush}"
                                 HorizontalAlignment="Center" />
                    </Border>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <!-- 文件名 -->
              <DataGridTextColumn Header="文件名"
                                  Binding="{Binding FileName, DataType=vm:JobItem}"
                                  Width="*"
                                  IsReadOnly="True" />

              <!-- 轨道数 -->
              <DataGridTextColumn Header="轨道"
                                  Binding="{Binding TrackCount, DataType=vm:JobItem}"
                                  Width="52"
                                  IsReadOnly="True" />

              <!-- 提取模式 -->
              <DataGridTextColumn Header="模式"
                                  Binding="{Binding ExtractionMode, DataType=vm:JobItem}"
                                  Width="120"
                                  IsReadOnly="True" />

              <!-- 进度条 -->
              <DataGridTemplateColumn Header="进度" Width="130" IsReadOnly="True">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate x:DataType="vm:JobItem">
                    <Grid ColumnDefinitions="*,36" Margin="4,0">
                      <ProgressBar Grid.Column="0" Minimum="0" Maximum="100"
                                   Value="{Binding Progress}"
                                   Height="8" CornerRadius="4"
                                   Foreground="{StaticResource MacaronMintBrush}"
                                   Background="#30000000"
                                   VerticalAlignment="Center" />
                      <TextBlock Grid.Column="1"
                                 Text="{Binding ProgressLabel}"
                                 FontSize="11"
                                 Foreground="{StaticResource MacaronTextSoftBrush}"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Right" />
                    </Grid>
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

              <!-- 耗时 -->
              <DataGridTextColumn Header="耗时"
                                  Binding="{Binding DurationLabel, DataType=vm:JobItem}"
                                  Width="68"
                                  IsReadOnly="True" />

              <!-- 错误信息 -->
              <DataGridTemplateColumn Header="错误" Width="160" IsReadOnly="True">
                <DataGridTemplateColumn.CellTemplate>
                  <DataTemplate x:DataType="vm:JobItem">
                    <TextBlock Text="{Binding ErrorMessage}"
                               FontSize="11"
                               Foreground="{StaticResource MacaronTextSoftBrush}"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center"
                               Margin="4,0"
                               ToolTip.Tip="{Binding ErrorMessage}" />
                  </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
              </DataGridTemplateColumn>

            </DataGrid.Columns>
          </DataGrid>
        </Grid>
      </Border>

      <!-- ── 当前任务进度 + 状态文本 ── -->
      <Grid Grid.Row="3" ColumnDefinitions="Auto,*" Margin="0,8,0,0">
        <TextBlock Grid.Column="0" Classes="subtitle" VerticalAlignment="Center"
                   Text="{Binding StatusText}" Margin="0,0,12,0" />
        <ProgressBar Grid.Column="1" Minimum="0" Maximum="100"
                     Value="{Binding CurrentTaskProgress}"
                     Height="8" CornerRadius="4"
                     Foreground="{StaticResource MacaronLavenderBrush}"
                     Background="#30000000"
                     IsVisible="{Binding IsRunning}" />
      </Grid>

      <!-- ── 完成摘要面板 ── -->
      <Border Grid.Row="4"
              IsVisible="{Binding IsSummaryVisible}"
              Classes="glass"
              Margin="0,10,0,0"
              Padding="16,12">
        <Grid ColumnDefinitions="*,Auto">
          <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="24">
            <StackPanel Orientation="Vertical" Spacing="2">
              <TextBlock Classes="subtitle" Text="成功" />
              <TextBlock Classes="h2" Text="{Binding CompletedCount}"
                         Foreground="{StaticResource MacaronMintBrush}" />
            </StackPanel>
            <StackPanel Orientation="Vertical" Spacing="2">
              <TextBlock Classes="subtitle" Text="失败" />
              <TextBlock Classes="h2" Text="{Binding FailedCount}"
                         Foreground="{StaticResource MacaronPinkBrush}" />
            </StackPanel>
            <StackPanel Orientation="Vertical" Spacing="2">
              <TextBlock Classes="subtitle" Text="跳过" />
              <TextBlock Classes="h2" Text="{Binding SkippedCount}"
                         Foreground="{StaticResource MacaronLemonBrush}" />
            </StackPanel>
            <StackPanel Orientation="Vertical" Spacing="2">
              <TextBlock Classes="subtitle" Text="总耗时" />
              <TextBlock Classes="h2" Text="{Binding TotalDurationLabel}"
                         Foreground="{StaticResource MacaronTextBrush}" />
            </StackPanel>
          </StackPanel>
          <Button Grid.Column="1" Classes="macaron" Content="✕ 关闭"
                  VerticalAlignment="Center"
                  Command="{Binding DismissSummaryCommand}" />
        </Grid>
      </Border>

    </Grid>
  </Panel>
</Window>

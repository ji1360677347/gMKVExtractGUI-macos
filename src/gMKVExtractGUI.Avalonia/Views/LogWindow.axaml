<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:gMKVToolNix.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        x:Class="gMKVToolNix.UI.Views.LogWindow"
        x:DataType="vm:LogWindowViewModel"
        Title="日志 · gMKVExtractGUI"
        Width="900" Height="600"
        MinWidth="600" MinHeight="400"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur,Mica,Blur,Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

  <Panel>
    <ExperimentalAcrylicBorder IsHitTestVisible="False">
      <ExperimentalAcrylicBorder.Material>
        <ExperimentalAcrylicMaterial
          BackgroundSource="Digger"
          TintColor="#CDE4F4"
          TintOpacity="0.55"
          MaterialOpacity="0.65" />
      </ExperimentalAcrylicBorder.Material>
    </ExperimentalAcrylicBorder>

    <Rectangle Fill="{DynamicResource MacaronWindowBackground}" Opacity="0.35" IsHitTestVisible="False" />

    <Grid Margin="20" RowDefinitions="Auto,*,Auto">

      <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,12,0,12">
        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2">
          <TextBlock Classes="h1" Text="日志" />
          <TextBlock Classes="subtitle" Text="实时跟踪 mkvtoolnix 调用与应用事件" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <CheckBox Content="自动滚动"
                    IsChecked="{Binding AutoScroll}"
                    Foreground="{DynamicResource MacaronTextBrush}" />
          <Button Classes="macaron lavender" Content="复制全部"
                  Command="{Binding CopyAllCommand}" />
          <Button Classes="macaron sky" Content="保存…"
                  Command="{Binding SaveAsCommand}" />
          <Button Classes="macaron" Content="清空"
                  Command="{Binding ClearCommand}" />
        </StackPanel>
      </Grid>

      <Border Grid.Row="1" Classes="glass" Padding="2">
        <ScrollViewer Name="LogScrollViewer"
                      HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Auto"
                      Background="#FFFCFCFE">
          <SelectableTextBlock Name="LogTextBlock"
                               Text="{Binding LogText}"
                               FontFamily="Menlo, Monaco, Consolas, monospace"
                               FontSize="12"
                               Padding="12"
                               Foreground="{DynamicResource MacaronTextBrush}"
                               TextWrapping="Wrap" />
        </ScrollViewer>
      </Border>

      <TextBlock Grid.Row="2" Classes="subtitle"
                 Text="{Binding StatusText}"
                 Margin="0,8,0,0" />
    </Grid>
  </Panel>
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:gMKVToolNix.UI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="780"
        x:Class="gMKVToolNix.UI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="gMKVExtractGUI"
        Width="1100" Height="780"
        MinWidth="900" MinHeight="620"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur,Mica,Blur,Transparent"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="-1">

  <Window.DataContext>
    <vm:MainWindowViewModel />
  </Window.DataContext>

  <Panel>

    <!-- 真毛玻璃 + 马卡龙 tint -->
    <ExperimentalAcrylicBorder IsHitTestVisible="False">
      <ExperimentalAcrylicBorder.Material>
        <ExperimentalAcrylicMaterial
          BackgroundSource="Digger"
          TintColor="#FFE2EA"
          TintOpacity="0.55"
          MaterialOpacity="0.65" />
      </ExperimentalAcrylicBorder.Material>
    </ExperimentalAcrylicBorder>

    <!-- 上层渐变 -->
    <Rectangle Fill="{DynamicResource MacaronWindowBackground}" Opacity="0.45" IsHitTestVisible="False" />

    <Grid Margin="20" RowDefinitions="Auto,Auto,*,Auto,Auto">

      <!-- 顶栏：标题 + 全局工具按钮 -->
      <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,12,0,12">
        <StackPanel Grid.Column="0" Orientation="Vertical" Spacing="2">
          <TextBlock Classes="h1" Text="gMKVExtractGUI" />
          <TextBlock Classes="subtitle"
                     Text="马卡龙版 · 拖入文件到任意位置即可加载" />
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Button Classes="macaron" Content="{Binding ThemeToggleText}" Command="{Binding ToggleThemeCommand}" />
          <Button Classes="macaron sky" Content="日志" Command="{Binding ShowLogCommand}" />
          <Button Classes="macaron lavender" Content="作业" Command="{Binding ShowJobsCommand}" />
          <Button Classes="macaron lemon" Content="设置" Command="{Binding ShowOptionsCommand}" />
        </StackPanel>
      </Grid>

      <!-- MKVToolnix 路径栏 -->
      <Border Grid.Row="1" Classes="glass" Margin="0,0,0,12" Padding="14,10">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
          <TextBlock Grid.Column="0" Classes="h2"
                     Text="MKVToolnix 路径"
                     VerticalAlignment="Center" Margin="0,0,12,0" />
          <TextBox Grid.Column="1" Classes="macaron"
                   Text="{Binding MkvToolnixPath}"
                   Watermark="（点击右侧自动探测，或浏览选择）"
                   Margin="0,0,8,0" />
          <Button Grid.Column="2" Classes="macaron sky" Content="浏览…"
                  Command="{Binding BrowseMkvToolnixPathCommand}" Margin="0,0,8,0" />
          <Button Grid.Column="3" Classes="macaron mint" Content="自动探测"
                  Command="{Binding AutoDetectMkvToolnixCommand}" />
        </Grid>
      </Border>

      <!-- 输入文件树：官方式单区布局，轨道始终展开 -->
      <Border Grid.Row="2" Classes="glass">
          <Border.ContextMenu>
            <ContextMenu>
              <MenuItem Header="{Binding CheckAllTracksHeader}" Command="{Binding CheckAllTracksCommand}" />
              <Separator />
              <MenuItem Header="{Binding CheckVideoTracksHeader}">
                <MenuItem Header="{Binding AllVideoTracksHeader}" Command="{Binding CheckVideoTracksCommand}" />
              </MenuItem>
              <MenuItem Header="{Binding CheckAudioTracksHeader}">
                <MenuItem Header="{Binding AllAudioTracksHeader}" Command="{Binding CheckAudioTracksCommand}" />
              </MenuItem>
              <MenuItem Header="{Binding CheckSubtitleTracksHeader}">
                <MenuItem Header="{Binding AllSubtitleTracksHeader}" Command="{Binding CheckSubtitleTracksCommand}" />
              </MenuItem>
              <MenuItem Header="{Binding CheckChapterTracksHeader}">
                <MenuItem Header="{Binding AllChapterTracksHeader}" Command="{Binding CheckChapterTracksCommand}" />
              </MenuItem>
              <MenuItem Header="{Binding CheckAttachmentTracksHeader}">
                <MenuItem Header="{Binding AllAttachmentTracksHeader}" Command="{Binding CheckAttachmentTracksCommand}" />
              </MenuItem>
              <Separator />
              <MenuItem Header="{Binding UncheckAllTracksHeader}" Command="{Binding UncheckAllTracksCommand}" />
              <Separator />
              <MenuItem Header="{Binding UncheckVideoTracksHeader}">
                <MenuItem Header="{Binding UncheckedVideoTracksHeader}" Command="{Binding UncheckVideoTracksCommand}" />
              </MenuItem>
              <MenuItem Header="{Binding UncheckAudioTracksHeader}">
                <MenuItem Header="{Binding UncheckedAudioTracksHeader}" Command="{Binding UncheckAudioTracksCommand}" />
              </MenuItem>
              <MenuItem Header="{Binding UncheckSubtitleTracksHeader}">
                <MenuItem Header="{Binding UncheckedSubtitleTracksHeader}" Command="{Binding UncheckSubtitleTracksCommand}" />
              </MenuItem>
              <MenuItem Header="{Binding UncheckChapterTracksHeader}">
                <MenuItem Header="{Binding UncheckedChapterTracksHeader}" Command="{Binding UncheckChapterTracksCommand}" />
              </MenuItem>
              <MenuItem Header="{Binding UncheckAttachmentTracksHeader}">
                <MenuItem Header="{Binding UncheckedAttachmentTracksHeader}" Command="{Binding UncheckAttachmentTracksCommand}" />
              </MenuItem>
            </ContextMenu>
          </Border.ContextMenu>
          <Grid RowDefinitions="Auto,Auto,*,Auto">
            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,8">
              <TextBlock Grid.Column="0" Classes="h2" Text="输入文件（可以拖放文件或者目录）" />
              <TextBlock Grid.Column="1" Classes="subtitle"
                         Text="{Binding TracksSummary}"
                         VerticalAlignment="Center" />
            </Grid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="18" Margin="0,0,0,8">
              <CheckBox Content="拖入时追加（不替换已有列表）"
                        IsChecked="{Binding AppendOnDragAndDrop}"
                        Foreground="{DynamicResource MacaronTextBrush}" />
              <CheckBox Content="覆盖已存在文件"
                        IsChecked="{Binding OverwriteExistingFiles}"
                        Foreground="{DynamicResource MacaronTextBrush}" />
              <CheckBox Content="禁用提示"
                        IsChecked="{Binding DisableTooltips}"
                        Foreground="{DynamicResource MacaronTextBrush}" />
            </StackPanel>

            <Border Grid.Row="2"
                    Name="DropZone"
                    Classes="drop-target"
                    Classes.active="{Binding IsDragOver}"
                    DragDrop.AllowDrop="True"
                    Padding="0">
              <Grid>
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            IsVisible="{Binding HasNoFiles}"
                            Spacing="8">
                  <TextBlock FontSize="40" Text="🍬" HorizontalAlignment="Center" />
                  <TextBlock Classes="h2" HorizontalAlignment="Center"
                             Text="拖入 MKV 文件到这里" />
                  <TextBlock Classes="subtitle" HorizontalAlignment="Center"
                             Text="或点击下方浏览" />
                  <Button Classes="macaron lavender"
                          Content="浏览…"
                          HorizontalAlignment="Center"
                          Margin="0,8,0,0"
                          Command="{Binding BrowseInputCommand}" />
                </StackPanel>

                <ListBox ItemsSource="{Binding InputFiles}"
                         SelectedItem="{Binding SelectedInputFile}"
                         Background="Transparent"
                         IsVisible="{Binding HasFiles}"
                         BorderThickness="0">
                  <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:InputFileItem">
                      <StackPanel Margin="4,4,4,6" Spacing="2">
                        <Grid ColumnDefinitions="*,Auto">
                          <TextBlock Grid.Column="0"
                                     Text="{Binding DisplayName}"
                                     ToolTip.Tip="{Binding FullPath}"
                                     Foreground="{DynamicResource MacaronTextBrush}"
                                     FontWeight="SemiBold"
                                     TextTrimming="CharacterEllipsis" />
                          <TextBlock Grid.Column="1"
                                     Text="{Binding TracksSummary}"
                                     Foreground="{DynamicResource MacaronTextSoftBrush}"
                                     FontSize="12"
                                     Margin="12,0,0,0"
                                     VerticalAlignment="Center" />
                        </Grid>
                        <TextBlock Text="正在解析轨道…"
                                   IsVisible="{Binding IsLoadingTracks}"
                                   Foreground="{DynamicResource MacaronTextSoftBrush}"
                                   FontSize="12"
                                   Margin="18,0,0,0" />
                        <ItemsControl ItemsSource="{Binding Tracks}">
                          <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:TrackItem">
                              <Grid ColumnDefinitions="Auto,Auto,*" Margin="18,1,0,1">
                                <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding TypeLabel}"
                                           Foreground="{DynamicResource MacaronTextSoftBrush}"
                                           FontSize="12"
                                           MinWidth="34"
                                           Margin="6,0,8,0"
                                           VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding Display}"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource MacaronTextBrush}"
                                           TextTrimming="CharacterEllipsis" />
                              </Grid>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </StackPanel>
                    </DataTemplate>
                  </ListBox.ItemTemplate>
                </ListBox>
              </Grid>
            </Border>

            <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8"
                        HorizontalAlignment="Right" Margin="0,8,0,0">
              <Button Classes="macaron" Content="添加输入文件..."
                      Command="{Binding BrowseInputCommand}" />
              <Button Classes="macaron lavender" Content="移除所选文件"
                      Command="{Binding RemoveSelectedFileCommand}" />
              <Button Classes="macaron sky" Content="清空"
                      Command="{Binding ClearInputFilesCommand}" />
            </StackPanel>
          </Grid>
        </Border>

      <!-- 输出路径栏 -->
      <Border Grid.Row="3" Classes="glass" Margin="0,12,0,8" Padding="14,10">
        <Grid ColumnDefinitions="Auto,*,Auto,Auto">
          <TextBlock Grid.Column="0" Classes="h2" Text="输出"
                     VerticalAlignment="Center" Margin="0,0,12,0" />
          <TextBox Grid.Column="1" Classes="macaron"
                   Text="{Binding OutputDirectory}"
                   IsEnabled="{Binding !UseSourceDirectory}"
                   Watermark="（使用源目录）" Margin="0,0,8,0" />
          <CheckBox Grid.Column="2" Content="使用源"
                    IsChecked="{Binding UseSourceDirectory}"
                    Foreground="{DynamicResource MacaronTextBrush}"
                    VerticalAlignment="Center" Margin="0,0,8,0" />
          <Button Grid.Column="3" Classes="macaron sky" Content="浏览"
                  Command="{Binding BrowseOutputCommand}" />
        </Grid>
      </Border>

      <!-- 操作栏 -->
      <Border Grid.Row="4" Classes="glass" Padding="14,10">
        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,Auto,Auto">
          <!-- 第一行：选项 -->
          <CheckBox Grid.Row="0" Grid.Column="0" Content="提取完成弹窗"
                    IsChecked="{Binding ShowPopup}"
                    Foreground="{DynamicResource MacaronTextBrush}"
                    VerticalAlignment="Center" Margin="0,0,16,0" />

          <TextBlock Grid.Row="0" Grid.Column="1" Text="章节："
                     VerticalAlignment="Center" Margin="0,0,4,0"
                     Foreground="{DynamicResource MacaronTextBrush}" />
          <ComboBox Grid.Row="0" Grid.Column="2"
                    ItemsSource="{Binding ChapterTypes}"
                    SelectedItem="{Binding SelectedChapterType}"
                    MinWidth="80" Margin="0,0,16,0" />

          <TextBlock Grid.Row="0" Grid.Column="3" Text="提取模式："
                     VerticalAlignment="Center" Margin="0,0,4,0"
                     Foreground="{DynamicResource MacaronTextBrush}" />
          <ComboBox Grid.Row="0" Grid.Column="4"
                    ItemsSource="{Binding ExtractionModes}"
                    SelectedItem="{Binding SelectedExtractionMode}"
                    MinWidth="180" HorizontalAlignment="Left" />

          <Button Grid.Row="0" Grid.Column="5" Classes="macaron lavender"
                  Content="加入队列" Margin="8,0,0,0"
                  Command="{Binding AddJobCommand}" />
          <Button Grid.Row="0" Grid.Column="6" Classes="macaron mint"
                  Content="提取 ▶" Margin="8,0,0,0"
                  Command="{Binding ExtractCommand}"
                  IsEnabled="{Binding !IsExtracting}" />
          <StackPanel Grid.Row="0" Grid.Column="7" Orientation="Horizontal" Spacing="6" Margin="8,0,0,0">
            <Button Classes="macaron" Content="中止"
                    Command="{Binding AbortCommand}"
                    IsEnabled="{Binding IsExtracting}" />
            <Button Classes="macaron" Content="全部中止"
                    Command="{Binding AbortAllCommand}"
                    IsEnabled="{Binding IsExtracting}" />
          </StackPanel>

          <!-- 第二行：状态/进度 -->
          <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="8"
                ColumnDefinitions="*,Auto" Margin="0,8,0,0">
            <ProgressBar Grid.Column="0"
                         Value="{Binding ProgressValue}"
                         Minimum="0" Maximum="100"
                         IsVisible="{Binding IsExtracting}"
                         Height="10" Margin="0,0,12,0"
                         Foreground="{DynamicResource MacaronPinkBrush}" />
            <TextBlock Grid.Column="0" Classes="subtitle"
                       Text="{Binding StatusText}"
                       IsVisible="{Binding !IsExtracting}"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Classes="subtitle"
                       Text="{Binding ProgressText}"
                       IsVisible="{Binding IsExtracting}"
                       VerticalAlignment="Center" />
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </Panel>
</Window>
